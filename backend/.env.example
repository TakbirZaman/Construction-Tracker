# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/constructtrack

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (optional, defaults used otherwise)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
